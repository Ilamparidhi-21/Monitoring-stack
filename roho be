pipeline {
    agent { label 'ubuntu-prod-agent' }

    environment {
        NODE_OPTIONS = '--max-old-space-size=4096'
        DEPLOY_DIR = "/home/ubuntu/roho-be-core"
        GIT_AUTHOR = ''
        GIT_COMMIT_MSG = ''
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Collect Git Info') {
            steps {
                script {
                    env.GIT_AUTHOR = sh(returnStdout: true, script: "git log -1 --pretty=format:'%an'").trim()
                    env.GIT_COMMIT_MSG = sh(returnStdout: true, script: "git log -1 --pretty=format:'%s'").trim()
                }
            }
        }

        stage('Install and Build') {
            steps {
                dir('roho_backend_core') {
                    sh '''
                        rm -rf out
                        npm install
                        npm run build
                    '''
                }
            }
        }

        stage('Deploy Backend') {
            steps {
                sh '''
                    mkdir -p ${DEPLOY_DIR}

                    rm -rf ${DEPLOY_DIR:?}/*

                    cp -r roho_backend_core/* ${DEPLOY_DIR}
                '''
            }
        }

        stage('Restart Backend') {
            steps {
                sh '''
                    cd ${DEPLOY_DIR}

                    pm2 restart roho-be-core || pm2 start npm --name roho-be-core -- start

                    pm2 save
                '''
            }
        }
    }

    post {
        success {
            script {
                def msg = """Backend Deployment Successful
Branch: ${env.GIT_BRANCH}
Author: ${env.GIT_AUTHOR}
Commit: ${env.GIT_COMMIT}
Message: ${env.GIT_COMMIT_MSG}
Build Logs: ${env.BUILD_URL}"""
                sendTelegramMessage(msg)
            }
        }

        failure {
            script {
                def msg = """Backend Deployment Failed
Branch: ${env.GIT_BRANCH}
Author: ${env.GIT_AUTHOR}
Commit: ${env.GIT_COMMIT}
Message: ${env.GIT_COMMIT_MSG}
Build Logs: ${env.BUILD_URL}"""
                sendTelegramMessage(msg)
            }
        }
    }
}

def sendTelegramMessage(String message) {
    withCredentials([
        string(credentialsId: 'TELEGRAM_BOT_TOKEN', variable: 'TOKEN'),
        string(credentialsId: 'TELEGRAM_CHAT_ID', variable: 'CHAT_ID')
    ]) {
        sh """
            curl -s -X POST \
            https://api.telegram.org/bot${TOKEN}/sendMessage \
            -d chat_id=${CHAT_ID} \
            --data-urlencode "text=${message}"
        """
    }
}
